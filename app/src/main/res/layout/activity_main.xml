<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 顶部进度条 -->
    <ProgressBar
        android:id="@+id/loadingProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentTop="true"
        android:visibility="gone"
        android:progressTint="#3DDC84" />

    <!-- WebView -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:layout_below="@id/loadingProgress" />

    <!-- 错误提示 -->
    <TextView
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:gravity="center"
        android:textSize="16sp"
        android:visibility="gone"
        android:padding="32dp"
        android:lineSpacingExtra="8dp" />

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- 首页 -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/nav_home_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home" />

            <TextView
                android:id="@+id/nav_home_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                android:textSize="10sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- 发现 -->
        <LinearLayout
            android:id="@+id/nav_page2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/nav_page2_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_discover" />

            <TextView
                android:id="@+id/nav_page2_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_page2"
                android:textSize="10sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- 消息 -->
        <LinearLayout
            android:id="@+id/nav_page3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/nav_page3_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_message" />

            <TextView
                android:id="@+id/nav_page3_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_page3"
                android:textSize="10sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- 我的 -->
        <LinearLayout
            android:id="@+id/nav_page4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/nav_page4_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile" />

            <TextView
                android:id="@+id/nav_page4_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_page4"
                android:textSize="10sp"
                android:textColor="#666666" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
