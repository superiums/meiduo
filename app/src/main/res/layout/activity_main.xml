<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 顶部进度条 -->
    <ProgressBar
        android:id="@+id/loadingProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentTop="true"
        android:visibility="gone"
        android:progressTint="#3DDC84" />

    <!-- WebView -->
<FrameLayout
    android:id="@+id/animationContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212" />

    <ImageView
        android:id="@+id/loadingIcon"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:src="@drawable/loading_animation" />

</FrameLayout>

<WebView
    android:id="@+id/webView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_below="@id/animationContainer"
    android:layout_above="@id/bottomNav" />

<!-- 错误提示 -->
<FrameLayout
    android:id="@+id/errorContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@id/bottomNav"
    android:visibility="gone">

    <ImageView
        android:id="@+id/errorSvg"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center_horizontal|top"
        android:src="@drawable/error_svg" />

    <TextView
        android:id="@+id/errorMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:text="网络错误，请检查网络连接"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp" />

</FrameLayout>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@color/bottom_nav_bg"
        android:elevation="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- 首页 -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/nav_home_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_home" />

            <TextView
                android:id="@+id/nav_home_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                android:textSize="10sp"
                android:textColor="@color/nav_text_normal" />
        </LinearLayout>

        <!-- 2 -->
        <LinearLayout
            android:id="@+id/nav_page2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/nav_page2_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_2" />

            <TextView
                android:id="@+id/nav_page2_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_page2"
                android:textSize="10sp"
                android:textColor="@color/nav_text_normal" />
        </LinearLayout>

        <!-- 3 -->
        <LinearLayout
            android:id="@+id/nav_page3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/nav_page3_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_3" />

            <TextView
                android:id="@+id/nav_page3_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_page3"
                android:textSize="10sp"
                android:textColor="@color/nav_text_normal" />
        </LinearLayout>

        <!-- 4 -->
        <LinearLayout
            android:id="@+id/nav_page4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/nav_page4_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_4" />

            <TextView
                android:id="@+id/nav_page4_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_page4"
                android:textSize="10sp"
                android:textColor="@color/nav_text_normal" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
